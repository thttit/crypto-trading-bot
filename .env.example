# Binance Futures API - Lấy tại: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Chế độ: paper (giả lập) hoặc live (thật)
TRADE_MODE=paper

# Ngưỡng confidence tối thiểu để ra lệnh (0.65 = 65% đến 0.90 = 90%)
MIN_CONFIDENCE=0.65

# Đòn bẩy mặc định (1-125)
DEFAULT_LEVERAGE=5

# Risk: % tài khoản mỗi lệnh, % SL, % TP
MAX_POSITION_PERCENT=0.05
STOP_LOSS_PERCENT=0.02
TAKE_PROFIT_PERCENT=0.04

# Giới hạn USDT cho mỗi lần vào lệnh (0 = không giới hạn; bot chia đều cho các coin)
LIMIT_USDT_PER_RUN=0

# Chạy lặp: khoảng cách giữa mỗi chu kỳ (phút) - dùng với run_loop.py
BOT_INTERVAL_MINUTES=60

# Tin tức (optional)
NEWS_API_KEY=
CRYPTO_NEWS_API_KEY=

# Testnet Binance (nếu dùng testnet)
# BINANCE_BASE_URL=https://testnet.binancefuture.com
